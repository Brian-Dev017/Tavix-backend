# Copia este archivo como application.properties y ajusta los valores
# cp application.properties.example application.properties

# Servidor
server.port=8080
spring.application.name=restaurante-backend

# Base de datos
spring.datasource.url=${DB_URL:jdbc:mysql://127.0.0.1:3306/restaurante?useSSL=false&serverTimezone=America/Lima&allowPublicKeyRetrieval=true}
spring.datasource.username=${DB_USER:root}
spring.datasource.password=${DB_PASSWORD:root}
spring.datasource.driver-class-name=com.mysql.cj.jdbc.Driver

# JPA / Hibernate
spring.jpa.hibernate.ddl-auto=update
spring.jpa.show-sql=false
spring.jpa.properties.hibernate.dialect=org.hibernate.dialect.MySQLDialect
spring.jpa.properties.hibernate.format_sql=true
spring.jpa.open-in-view=false

# JWT
app.jwt.secret=${JWT_SECRET:clave-super-secreta-restaurante-2026-min-256bits-reemplazar-en-prod}
app.jwt.access-expiration-ms=${JWT_ACCESS_MS:600000}
app.jwt.refresh-expiration-days=${JWT_REFRESH_DAYS:7}

# CORS
app.cors.allowed-origins=http://localhost:5173,http://localhost:5174

# Logging
logging.level.com.restaurante=INFO
logging.level.org.springframework.security=WARN
